<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Post</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Quora Post</h1>
    <% for (post of posts){%>
        <div class="post">
            <h3 class="user">@<%= post.username %></h3>
            <h4 class="content"><%= post.content %></h4>
            <br>
            <a href="/post/<%= post.id %>">See in details</a>
        <a href="/post/<%= post.id %>/edit">Edit</a>    
        <br><br>
        <form method="post" action="/post/<%= post.id%>?_method=DELETE"><button>Delete Post</button></form>
        
        </div>
    <%}%>
        <br><br>
        <a href="http://localhost:8080/post/new">Create New Post</a>

</body>
</html>

