<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delete Post</title>
</head>
<body>
    <h2>
        To delete data of user with email: <%= user.email%>
    </h2>
    <form action="/user/<%= user.id%>,by entering password" method="post">
        <input name="password" placeholder="Enter your password">
        <button>Delete</button>
    </form>
</body>
</html>